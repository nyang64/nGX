# ============================================================
# nGX Environment Configuration
# Copy this file to .env and fill in actual values.
# Never commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
ENVIRONMENT=development          # development | staging | production
LOG_LEVEL=debug                  # debug | info | warn | error
LOG_FORMAT=text                  # text | json

# ------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------
DATABASE_URL=postgres://agentmail:agentmail_dev@localhost:5432/agentmail?sslmode=disable
DB_MAX_CONNS=25                  # Maximum open connections in pool
DB_MIN_CONNS=5                   # Minimum idle connections in pool
DB_MAX_CONN_LIFETIME_SEC=3600    # Max lifetime of a pooled connection (seconds)
DB_MAX_CONN_IDLE_SEC=300         # Max idle time before connection is closed (seconds)

# ------------------------------------------------------------
# Kafka
# ------------------------------------------------------------
KAFKA_BROKERS=localhost:9092     # Comma-separated broker list
KAFKA_GROUP_ID=agentmail         # Consumer group ID
# Topic names are hardcoded in pkg/kafka/topics.go and are not configurable via env.

# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------
# S3 / MinIO Object Storage
# ------------------------------------------------------------
S3_ENDPOINT=http://localhost:9000          # Empty for AWS S3, set for MinIO
S3_REGION=us-east-1
S3_BUCKET=agentmail
S3_ACCESS_KEY_ID=agentmail_minio
S3_SECRET_ACCESS_KEY=agentmail_minio_dev_secret
S3_USE_PATH_STYLE=true                    # true for MinIO, false for AWS S3

# ------------------------------------------------------------
# API Service
# ------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8080

# ------------------------------------------------------------
# Inter-service Auth
# ------------------------------------------------------------
INTERNAL_SECRET=dev-internal-secret-change-in-prod   # HMAC key for inter-service calls

# ------------------------------------------------------------
# Service URLs (used by API gateway to route requests)
# ------------------------------------------------------------
AUTH_SERVICE_URL=http://localhost:8081
INBOX_SERVICE_URL=http://localhost:8082
WEBHOOK_SERVICE_URL=http://localhost:8083
SEARCH_SERVICE_URL=http://localhost:8084

# ------------------------------------------------------------
# SMTP / Email Ingestion (email-pipeline service)
# ------------------------------------------------------------
SMTP_LISTEN_ADDR=0.0.0.0:2525            # Address the email-pipeline listens on for inbound SMTP
SMTP_HOSTNAME=localhost                   # Domain claimed in SMTP EHLO
# Route all outbound mail through this host:port instead of doing live MX lookups.
# Use MailHog (localhost:1025) in dev. Leave empty in production to use real MX delivery.
SMTP_RELAY_HOST=localhost:1025

# DKIM signing (outbound)
# Generate a key pair: openssl genrsa -out dkim.pem 2048
# Publish the public key as a DNS TXT record: {DKIM_SELECTOR}._domainkey.{DKIM_DOMAIN}
DKIM_PRIVATE_KEY_PEM=                     # PEM-encoded RSA or Ed25519 private key (leave empty to disable)
MAIL_DOMAIN=                              # Default domain for inbox provisioning (e.g. mail.yourdomain.com) — required
DKIM_SELECTOR=mail                        # DNS selector subdomain (publish at {DKIM_SELECTOR}._domainkey.{DKIM_DOMAIN})
DKIM_DOMAIN=                             # Signing domain — must match MAIL_DOMAIN or a verified custom domain

# ------------------------------------------------------------
# Webhook Service
# ------------------------------------------------------------
WEBHOOK_PORT=8083
WEBHOOK_CONCURRENCY=10                    # Number of concurrent webhook delivery workers
WEBHOOK_MAX_RETRIES=8                     # Maximum delivery retry attempts (uses 2^attempt seconds backoff, capped at 4096s)
# AES-256 key for encrypting caller-supplied auth header values at rest.
# Generate with: openssl rand -hex 32
WEBHOOK_ENCRYPTION_KEY=                   # 64-char hex string — required in production

# ------------------------------------------------------------
# Scheduler Service (cron jobs only — no HTTP port)
# ------------------------------------------------------------

# ------------------------------------------------------------
# Search Service (listens on port 8084 — hardcoded)
# ------------------------------------------------------------

# ------------------------------------------------------------
# Embedder Service (Infinity / Ollama)
# Set EMBEDDER_URL to enable semantic search.
# In dev this points to the Infinity container in docker-compose.
# Leave empty to disable semantic search (keyword-only).
# ------------------------------------------------------------
EMBEDDER_URL=http://localhost:7997
EMBEDDER_MODEL=nomic-embed-text-v1.5

# ------------------------------------------------------------
# Event Dispatcher (Kafka consumer only — no HTTP port)
# ------------------------------------------------------------

# ------------------------------------------------------------
# Observability / OpenTelemetry
# Tracing is enabled when OTEL_ENDPOINT is non-empty.
# ------------------------------------------------------------
OTEL_ENDPOINT=http://localhost:4318       # OTLP HTTP endpoint (Jaeger, Tempo, etc.)
OTEL_SERVICE_NAME=agentmail
