# ============================================================
# nGX Environment Configuration
# Copy this file to .env and fill in the values marked (YOU SET THIS).
# Never commit .env or .env.outputs to version control.
#
# Two-file model:
#   .env          — pre-deploy inputs you supply once (TF_VAR_*, static config)
#   .env.outputs  — post-deploy values auto-generated by scripts/sync-env.sh
#
# Workflow:
#   1. cp .env.example .env  && fill in all (YOU SET THIS) values
#   2. source loadenv.sh && AWS_PROFILE=<profile> terraform -chdir=terraform apply
#   3. scripts/sync-env.sh          # generates .env.outputs
#   4. source loadenv.sh            # picks up both .env and .env.outputs
# ============================================================

# ------------------------------------------------------------
# Terraform Variables (AWS Serverless Stack)
# These map directly to terraform/variables.tf via TF_VAR_ prefix.
# source loadenv.sh exports them; no -var flags or tfvars file needed.
# ------------------------------------------------------------
TF_VAR_app_name=ngx
TF_VAR_environment=prod
TF_VAR_aws_region=us-east-1
# Subdomain delegated to SES for inbound/outbound mail (e.g. mail.yourdomain.com)
TF_VAR_mail_domain=mail.example.com
TF_VAR_db_name=ngx
TF_VAR_db_username=ngxadmin
# Generate: openssl rand -hex 32
TF_VAR_webhook_encryption_key=
# Optional: embedding server URL (leave empty to disable semantic search)
TF_VAR_embedder_url=
TF_VAR_embedder_model=nomic-embed-text-v1.5
# Optional capacity overrides (defaults shown)
# TF_VAR_vpc_cidr=10.0.0.0/16
# TF_VAR_aurora_min_capacity=0.5
# TF_VAR_aurora_max_capacity=16
# TF_VAR_webhook_max_retries=8

# ------------------------------------------------------------
# Application Runtime
# development | staging | production
# ------------------------------------------------------------
ENVIRONMENT=production
# debug | info | warn | error
LOG_LEVEL=info
# text | json
LOG_FORMAT=json

# ------------------------------------------------------------
# AWS
# ------------------------------------------------------------
# AWS_PROFILE=my-aws-profile   (YOU SET THIS — or use AWS_* credential env vars)
AWS_REGION=us-east-1

# ------------------------------------------------------------
# PostgreSQL (Aurora via RDS Proxy)
# DATABASE_URL is populated into .env.outputs by scripts/sync-env.sh.
# For a local psql/migration session via SSM tunnel, forward Aurora to localhost:15432:
#   aws ssm start-session --profile <profile> --region us-east-1 \
#     --target <bastion-instance-id> \
#     --document-name AWS-StartPortForwardingSessionToRemoteHost \
#     --parameters '{"host":["<rds-proxy-endpoint>"],"portNumber":["5432"],"localPortNumber":["15432"]}'
# ------------------------------------------------------------
DB_MAX_CONNS=25
DB_MIN_CONNS=2
DB_MAX_CONN_LIFETIME_SEC=3600
DB_MAX_CONN_IDLE_SEC=300

# ------------------------------------------------------------
# SES
# ------------------------------------------------------------
SES_CONFIGURATION_SET=ngx-prod-sending
SES_RULE_SET_NAME=ngx-prod-receipt-rules

# ------------------------------------------------------------
# Email
# Must match TF_VAR_mail_domain above.
# ------------------------------------------------------------
MAIL_DOMAIN=mail.example.com

# ------------------------------------------------------------
# Webhook Service
# Same value as TF_VAR_webhook_encryption_key — Lambdas receive it via terraform.
# ------------------------------------------------------------
WEBHOOK_MAX_RETRIES=8
WEBHOOK_ENCRYPTION_KEY=${TF_VAR_webhook_encryption_key}

# ------------------------------------------------------------
# Embedder / Semantic Search (leave empty to disable)
# ------------------------------------------------------------
EMBEDDER_URL=
EMBEDDER_MODEL=nomic-embed-text-v1.5

# ------------------------------------------------------------
# Observability / OpenTelemetry (leave empty to disable tracing)
# ------------------------------------------------------------
OTEL_ENDPOINT=
OTEL_SERVICE_NAME=ngx

# ------------------------------------------------------------
# Post-deploy outputs — DO NOT SET MANUALLY
# Generated by scripts/sync-env.sh into .env.outputs after terraform apply.
# Documented here for reference only.
# ------------------------------------------------------------
# DATABASE_URL=postgres://ngxadmin:<pass>@<rds-proxy>:5432/ngx?sslmode=require
# S3_BUCKET=<bucket-name>
# SQS_EMAIL_INBOUND_URL=https://sqs.us-east-1.amazonaws.com/...
# SQS_EMAIL_OUTBOUND_URL=https://sqs.us-east-1.amazonaws.com/...
# SQS_WEBHOOK_DELIVERY_URL=https://sqs.us-east-1.amazonaws.com/...
# SQS_WS_DISPATCH_URL=https://sqs.us-east-1.amazonaws.com/...
# SQS_EMBEDDER_URL=https://sqs.us-east-1.amazonaws.com/...
# SQS_SES_EVENTS_URL=https://sqs.us-east-1.amazonaws.com/...
# REST_API_ENDPOINT=https://<id>.execute-api.us-east-1.amazonaws.com/v1
# APIGW_WEBSOCKET_ENDPOINT=wss://<id>.execute-api.us-east-1.amazonaws.com/prod
