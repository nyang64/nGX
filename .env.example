# ============================================================
# nGX Environment Configuration
# Copy this file to .env and fill in actual values.
# Never commit .env to version control.
#
# AWS Serverless stack (aws-serverless-stack branch):
#   source loadenv.sh && AWS_PROFILE=<profile> terraform plan
#   TF_VAR_* variables below are picked up automatically by Terraform.
# ============================================================

# ------------------------------------------------------------
# Terraform Variables (AWS Serverless Stack)
# These map directly to terraform/variables.tf via TF_VAR_ prefix.
# source loadenv.sh exports them; no -var flags or tfvars file needed.
# ------------------------------------------------------------
TF_VAR_app_name=ngx
TF_VAR_environment=prod
TF_VAR_aws_region=us-east-1
TF_VAR_mail_domain=mail.example.com
TF_VAR_db_name=ngx
TF_VAR_db_username=ngxadmin
# Generate: openssl rand -hex 32
TF_VAR_webhook_encryption_key=
TF_VAR_embedder_url=
TF_VAR_embedder_model=nomic-embed-text-v1.5
# Optional overrides (defaults shown)
# TF_VAR_vpc_cidr=10.0.0.0/16
# TF_VAR_aurora_min_capacity=0.5
# TF_VAR_aurora_max_capacity=16
# TF_VAR_webhook_max_retries=8

# ------------------------------------------------------------
# Application
# development | staging | production
# ------------------------------------------------------------
ENVIRONMENT=development
# debug | info | warn | error
LOG_LEVEL=debug
# text | json
LOG_FORMAT=text

# ------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------
DATABASE_URL=postgres://agentmail:agentmail_dev@localhost:5432/agentmail?sslmode=disable
# Maximum open connections in pool
DB_MAX_CONNS=25
# Minimum idle connections in pool
DB_MIN_CONNS=5
# Max lifetime of a pooled connection (seconds)
DB_MAX_CONN_LIFETIME_SEC=3600
# Max idle time before connection is closed (seconds)
DB_MAX_CONN_IDLE_SEC=300

# ------------------------------------------------------------
# Kafka
# Comma-separated broker list
# Topic names are hardcoded in pkg/kafka/topics.go and are not configurable via env.
# ------------------------------------------------------------
KAFKA_BROKERS=localhost:9092
# Consumer group ID
KAFKA_GROUP_ID=agentmail

# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------
# S3 / MinIO Object Storage
# Empty for AWS S3, set for MinIO
# ------------------------------------------------------------
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=agentmail
S3_ACCESS_KEY_ID=agentmail_minio
S3_SECRET_ACCESS_KEY=agentmail_minio_dev_secret
# true for MinIO, false for AWS S3
S3_USE_PATH_STYLE=true

# ------------------------------------------------------------
# API Service
# ------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8080

# ------------------------------------------------------------
# Inter-service Auth
# HMAC key for inter-service calls
# ------------------------------------------------------------
INTERNAL_SECRET=dev-internal-secret-change-in-prod

# ------------------------------------------------------------
# Service URLs (used by API gateway to route requests)
# ------------------------------------------------------------
AUTH_SERVICE_URL=http://localhost:8081
INBOX_SERVICE_URL=http://localhost:8082
WEBHOOK_SERVICE_URL=http://localhost:8083
SEARCH_SERVICE_URL=http://localhost:8084

# ------------------------------------------------------------
# SMTP / Email Ingestion (email-pipeline service)
# ------------------------------------------------------------
# Address the email-pipeline listens on for inbound SMTP
SMTP_LISTEN_ADDR=0.0.0.0:2525
# Hostname claimed in SMTP EHLO (e.g. mail.yourdomain.com)
SMTP_HOSTNAME=localhost
# Route all outbound mail through this host:port instead of doing live MX lookups.
# Use localhost:1025 for MailHog in dev. Leave empty in production to use real MX delivery.
SMTP_RELAY_HOST=localhost:1025

# DKIM signing (outbound)
# Generate a key pair: openssl genrsa -out dkim.pem 2048
# Publish the public key as a DNS TXT record: {DKIM_SELECTOR}._domainkey.{DKIM_DOMAIN}
# PEM-encoded RSA or Ed25519 private key (leave empty to disable)
DKIM_PRIVATE_KEY_PEM=
# Default domain for inbox provisioning (e.g. yourdomain.com) — required in production
MAIL_DOMAIN=
# DNS selector subdomain (publish at {DKIM_SELECTOR}._domainkey.{DKIM_DOMAIN})
DKIM_SELECTOR=mail
# Signing domain — must match MAIL_DOMAIN or a verified custom domain
DKIM_DOMAIN=

# ------------------------------------------------------------
# Webhook Service
# ------------------------------------------------------------
WEBHOOK_PORT=8083
# Number of concurrent webhook delivery workers
WEBHOOK_CONCURRENCY=10
# Maximum delivery retry attempts (uses 2^attempt seconds backoff, capped at 4096s)
WEBHOOK_MAX_RETRIES=8
# AES-256 key for encrypting caller-supplied auth header values at rest.
# Generate with: openssl rand -hex 32
# 64-char hex string — required in production
WEBHOOK_ENCRYPTION_KEY=

# ------------------------------------------------------------
# Scheduler Service (cron jobs only — no HTTP port)
# ------------------------------------------------------------

# ------------------------------------------------------------
# Search Service (listens on port 8084 — hardcoded)
# ------------------------------------------------------------

# ------------------------------------------------------------
# Embedder Service (Infinity / Ollama)
# Set EMBEDDER_URL to enable semantic search.
# In dev this points to the Infinity container in docker-compose.
# Leave empty to disable semantic search (keyword-only).
# ------------------------------------------------------------
EMBEDDER_URL=http://localhost:7997
EMBEDDER_MODEL=nomic-embed-text-v1.5

# ------------------------------------------------------------
# Event Dispatcher (Kafka consumer only — no HTTP port)
# ------------------------------------------------------------

# ------------------------------------------------------------
# Observability / OpenTelemetry
# Tracing is enabled when OTEL_ENDPOINT is non-empty.
# OTLP HTTP endpoint (Jaeger, Tempo, etc.)
# ------------------------------------------------------------
OTEL_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=agentmail
